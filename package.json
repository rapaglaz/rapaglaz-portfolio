{
  "name": "rapaglaz-portfolio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage --watch=false",
    "lint": "ng lint",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "i18n:validate": "transloco-validator public/i18n/*.json",
    "i18n:find": "transloco-keys-manager find",
    "i18n:check": "pnpm run i18n:validate && pnpm run i18n:find",
    "preview": "serve dist/rapaglaz-portfolio/browser -l 4233",
    "e2e": "ng e2e",
    "e2e:ui": "ng e2e --ui",
    "e2e:ssg": "pnpm run build && E2E_MODE=ssg pnpm exec playwright test",
    "e2e:ssg:ui": "pnpm run build && E2E_MODE=ssg pnpm exec playwright test --ui",
    "clean": "rm -rf .angular && rm -rf node_modules",
    "clean:reinstall": "pnpm run clean && pnpm install",
    "prepare": "[ -n \"$CI\" ] || lefthook install"
  },
  "dependencies": {
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.3",
    "@angular/compiler": "22.0.3",
    "@angular/core": "22.0.3",
    "@angular/forms": "22.0.3",
    "@angular/platform-browser": "22.0.3",
    "@angular/platform-server": "22.0.3",
    "@angular/router": "22.0.3",
    "@angular/ssr": "22.0.4",
    "@fontsource/inter": "5.2.8",
    "@fontsource/manrope": "5.2.8",
    "@jsverse/transloco": "8.3.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.3",
    "@axe-core/playwright": "4.11.3",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@jsverse/transloco-keys-manager": "8.1.0",
    "@jsverse/transloco-utils": "8.3.0",
    "@jsverse/transloco-validator": "8.3.0",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "angular-eslint": "22.0.0",
    "daisyui": "5.5.23",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "jsdom": "29.1.1",
    "lefthook": "2.1.9",
    "lint-staged": "17.0.8",
    "playwright-ng-schematics": "21.1.1",
    "postcss": "8.5.16",
    "prettier": "3.8.5",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "serve": "14.2.6",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
