{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":pinAllExceptPeerDependencies"],
  "dependencyDashboardTitle": "Dependency Dashboard",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardAutoclose": true,
  "rangeStrategy": "bump",
  "platformAutomerge": true,
  "prConcurrentLimit": 4,
  "prHourlyLimit": 4,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 3am on Monday"],
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash"
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Create PR for minor updates",
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": "!/^0/",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Automerge patch updates for stable versions",
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "minimumReleaseAge": "1 day"
    },
    {
      "description": "Require approval for unstable versions (0.x)",
      "matchCurrentVersion": "/^0/",
      "matchUpdateTypes": ["minor", "patch"],
      "dependencyDashboardApproval": true,
      "labels": ["unstable-version"]
    },
    {
      "description": "Automerge patch vulnerability alerts; prioritise all security updates",
      "isVulnerabilityAlert": true,
      "matchUpdateTypes": ["major", "minor", "patch"],
      "prPriority": 10,
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Group Angular",
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "Angular packages",
      "groupSlug": "angular",
      "matchPackageNames": [
        "@angular/{/,}**",
        "@angular-devkit/{/,}**",
        "@angular-eslint/{/,}**"
      ]
    },
    {
      "description": "Group vitest",
      "matchPackageNames": ["vitest", "@vitest/coverage-v8"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "Vitest",
      "groupSlug": "vitest"
    }
  ]
}
