{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":pinAllExceptPeerDependencies"],
  "dependencyDashboardTitle": "Dependency Dashboard",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardAutoclose": true,
  "rangeStrategy": "bump",
  "platformAutomerge": true,
  "prConcurrentLimit": 4,
  "rebaseWhen": "behind-base-branch",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on Monday"],
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash"
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Create PR for minor updates",
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": "!/^0/",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Automerge patch updates for stable versions",
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Require approval for unstable versions (0.x)",
      "matchCurrentVersion": "/^0/",
      "matchUpdateTypes": ["minor", "patch"],
      "dependencyDashboardApproval": true,
      "labels": ["unstable-version"]
    },
    {
      "description": "Automerge patch vulnerability alerts; prioritise all security updates",
      "isVulnerabilityAlert": true,
      "matchUpdateTypes": ["major", "minor", "patch"],
      "prPriority": 10,
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Group Angular",
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "Angular packages",
      "groupSlug": "angular",
      "matchPackageNames": [
        "@angular/{/,}**",
        "@angular-devkit/{/,}**",
        "@angular-eslint/{/,}**"
      ]
    },
    {
      "description": "Group vitest",
      "matchPackageNames": ["vitest", "@vitest/coverage-v8"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "Vitest",
      "groupSlug": "vitest"
    },
    {
      "description": "Group pnpm ecosystem",
      "matchPackageNames": ["pnpm", "pnpm/action-setup"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "pnpm",
      "groupSlug": "pnpm"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "matchPackageNames": ["!pnpm/action-setup"]
    },
    {
      "description": "Group TypeScript tooling",
      "matchPackageNames": ["typescript-eslint", "@types/{/,}**"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "TypeScript tooling",
      "groupSlug": "typescript-tooling"
    },
    {
      "description": "Group commitlint",
      "matchPackageNames": ["@commitlint/{/,}**"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "commitlint",
      "groupSlug": "commitlint"
    },
    {
      "description": "Group Playwright testing",
      "matchPackageNames": [
        "@playwright/test",
        "@axe-core/playwright",
        "playwright-ng-schematics",
        "mcr.microsoft.com/playwright"
      ],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "groupName": "Playwright testing",
      "groupSlug": "playwright-testing"
    }
  ]
}
